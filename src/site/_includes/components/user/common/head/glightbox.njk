<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var content = document.querySelector('.markdown-preview-view') || document.body;

  content.querySelectorAll('img').forEach(function(img) {
    if (!img.src.includes('/img/user/')) return;
    if (img.closest('a.glightbox')) return;

    var alt = (img.getAttribute('alt') || '').trim();

    if (alt) {
      // 模式 1:alt 有内容 → 替换为文字链接,文字就是 alt
      var a = document.createElement('a');
      a.href = img.src;
      a.className = 'glightbox img-link';
      a.setAttribute('data-gallery', 'page-gallery');
      a.textContent = alt;

      var target = img.closest('picture') || img;
      target.parentNode.replaceChild(a, target);
    } else {
      // 模式 2:alt 为空 → 正常显示图片,包一层 lightbox 让它可点击放大
      if (img.parentNode.tagName === 'A') return;
      var wrap = document.createElement('a');
      wrap.href = img.src;
      wrap.className = 'glightbox';
      wrap.setAttribute('data-gallery', 'page-gallery');
      img.parentNode.insertBefore(wrap, img);
      wrap.appendChild(img);
      img.classList.add('thumb-img');
    }
  });

  if (typeof GLightbox !== 'undefined') {
    GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true
    });
  }
});
</script>
