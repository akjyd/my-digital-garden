<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var content = document.querySelector('.markdown-preview-view') || document.body;

  // 1. 自动给笔记内的图片包 lightbox 链接(保持你已有的功能)
  content.querySelectorAll('img').forEach(function(img) {
    if (img.parentNode.tagName === 'A') return;
    if (!img.src.includes('/img/user/')) return;

    var a = document.createElement('a');
    a.href = img.src;
    a.className = 'glightbox';
    a.setAttribute('data-gallery', 'page-gallery');
    img.parentNode.insertBefore(a, img);
    a.appendChild(img);
    img.classList.add('thumb-img');
  });

  // 2. 新增:把指向图片文件的文字链接也接管成 lightbox
  content.querySelectorAll('a').forEach(function(a) {
    // 已经是 glightbox 的跳过
    if (a.classList.contains('glightbox')) return;
    // 链接内部已经包了 img 的跳过(避免重复处理)
    if (a.querySelector('img')) return;
    // 只处理 href 指向图片文件的
    if (!/\.(png|jpe?g|webp|gif)$/i.test(a.href)) return;

    a.classList.add('glightbox');
    a.setAttribute('data-gallery', 'page-gallery');
  });

  if (typeof GLightbox !== 'undefined') {
    GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true
    });
  }
});
</script>
